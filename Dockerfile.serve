FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    "mlflow==2.19.0" \
    "scikit-learn>=1.3" \
    "pandas>=2.0" \
    "numpy>=1.24"

COPY model_artifacts/ /app/model/

EXPOSE 8080

CMD ["mlflow", "models", "serve", \
     "-m", "/app/model", \
     "--host", "0.0.0.0", \
     "--port", "8080", \
     "--env-manager", "local"]
